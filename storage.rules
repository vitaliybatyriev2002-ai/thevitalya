rules_version = '2';

// Security rules for theVITALYA forum's Firebase Storage bucket (post/reply
// image and media uploads).
//
// HOW TO APPLY: Firebase Console → your project (thevitalya-39d42) →
// Storage → Rules tab → paste this file's contents → Publish.
// The agent cannot publish these for you — it requires direct Firebase
// project access that isn't available here.
//
// Without these rules, Storage falls back to Firebase's default (deny all
// reads/writes, or a time-limited "test mode" that expires), which is why
// uploading an image/media file when creating a topic or reply can silently
// fail with a permission error.

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Forum post/reply attachments: any signed-in (non-banned-check is
    // enforced by Firestore rules on the post/reply document itself) user
    // may upload an image/video up to 15 MB. Anyone can read/view media in
    // the forum since posts themselves are publicly readable.
    match /forum_posts/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn()
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*');
    }

    match /forum_replies/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn()
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
